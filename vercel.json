{
  "version": 2,
  "crons": [
    {
      "path": "/api/relances/devis",
      "schedule": "0 8 * * *"
    }
  ],
  "builds": [
    { "src": "api/relances-devis-cron.js", "use": "@vercel/node" },
    { "src": "api/index.js", "use": "@vercel/node" },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public",
        "outputDirectory": "public",
        "buildCommand": "npm run vercel-build"
      }
    }
  ],
  "routes": [
    { "src": "/api/relances/devis", "dest": "/api/relances-devis-cron.js" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/sign/(.*)", "dest": "/api/index.js" },
    { "src": "/auth/(.*)", "dest": "/api/index.js" },
    { "src": "/public/(sign|accept)/(.*)", "dest": "/api/index.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/index.html", "dest": "/index.html" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
