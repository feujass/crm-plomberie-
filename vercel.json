{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/auth/(.*)", "dest": "/api/index.js" },
    { "src": "/public/(.*)", "dest": "/api/index.js" },
    { "src": "/styles.css", "dest": "/public/styles.css" },
    { "src": "/app.js", "dest": "/public/app.js" },
    { "src": "/index.html", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
